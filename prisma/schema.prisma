datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  nickname      String    @unique
  referredBy    String?
  submissions   Submission[]
  streak        Streak?
  badges        UserBadge[]
  
  // Stats
  totalSolved     Int     @default(0)
  correctAnswers  Int     @default(0)
  totalSolveTime  Int     @default(0) // in seconds
  averageSolveTime Float?
  accuracy        Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Challenge {
  id            String   @id @default(cuid())
  question      String
  options       String?    // JSON string
  answer        String
  explanation   String
  difficulty    String   // Easy, Medium, Hard
  topic         String
  publishedAt   DateTime @unique // The day this challenge is for (midnight UTC)
  image         String?
  submissions   Submission[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Submission {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  answer      String
  isCorrect   Boolean
  solvedTime  Int      // seconds
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
}

model Streak {
  id                String   @id @default(cuid())
  userId            String   @unique
  currentStreak     Int      @default(0)
  longestStreak     Int      @default(0)
  lastSubmissionAt  DateTime?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  icon        String      // Lucide icon name
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model LeaderboardSnapshot {
  id        String   @id @default(cuid())
  type      String   // daily, weekly, monthly, all-time
  data      String     // JSON string
  timestamp DateTime @default(now())
}
